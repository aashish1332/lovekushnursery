{
  "rewrites": [
    { "source": "/api/(.*)", "destination": "https://lovekushnursery.vercel.app/api/$1" },
    { "source": "/admin/(.*)", "destination": "https://lovekushnursery.vercel.app/admin/$1" },
    { "source": "/((?!assets/).*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
