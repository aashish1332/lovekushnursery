# ============================================================
# Love Kush Nursery — Backend Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# ============================================================

# ── TiDB Cloud Database ────────────────────────────────────
# Format: mysql://USER:PASSWORD@HOST:4000/DATABASE?sslaccept=strict
# Get from: https://tidbcloud.com → Your Cluster → Connect
DATABASE_URL="mysql://username:password@gateway01.us-west-2.prod.aws.tidbcloud.com:4000/nursery_db?sslaccept=strict"

# ── GitHub (for image uploads) ──────────────────────────────
# Create a Personal Access Token with 'repo' scope
# https://github.com/settings/tokens
GITHUB_TOKEN="ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# GitHub username or organization
GITHUB_OWNER="yoema261-glitch"

# Repository name (must exist, will use /plants/ folder)
GITHUB_REPO="images"

# ── Admin Credentials ──────────────────────────────────────
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="lovekush2024"

# ── Frontend URL (for CORS) ────────────────────────────────
FRONTEND_URL="http://localhost:5173"

# ── Optional ────────────────────────────────────────────────
# Max image dimension (larger images will be resized)
MAX_IMAGE_WIDTH=1920
MAX_IMAGE_HEIGHT=1080

# WebP quality (1-100)
WEBP_QUALITY=82
